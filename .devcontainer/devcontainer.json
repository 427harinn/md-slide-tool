{
    "name": "md-slide-tool",
    "build": {
        "dockerfile": "../Dockerfile"
    },
    "workspaceFolder": "/work",
    "mounts": [
        "source=${localWorkspaceFolder},target=/work,type=bind"
    ],
    "postCreateCommand": "npm install && npm link && grep -qxF 'source /work/completions/slidegen.bash' ~/.bashrc || echo 'source /work/completions/slidegen.bash' >> ~/.bashrc",
    "customizations": {
        "vscode": {
            "extensions": [
                "quarto.quarto",
                "yzhang.markdown-all-in-one",
                "AdamRaichu.pdf-viewer",
                "Gruntfuggly.triggertaskonsave"
            ],
            "settings": {
                "triggerTaskOnSave.tasks": {
                    "Quarto Build": [
                        "projects/**/*.qmd"
                    ]
                }
            }
        }
    }
}